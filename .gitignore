# Secrets — must never be committed
*.gpg
.authinfo
.authinfo.gpg
*-secrets.el
auth-source-cache*
.netrc

# Nix
result
result-*

# macOS
.DS_Store

# IDE / editor metadata
.idea/

# Emacs runtime / generated
emacs/eln-cache/
emacs/elpaca/
emacs/auto-save-list/
emacs/*.elc
emacs/transient/
emacs/var/
custom.el

# Machine-local Emacs config (never commit — enterprise hosts, etc.)
# Primary location is ~/.config/emacs-local/ (outside this repo). This pattern
# is a belt-and-suspenders guard in case a local.el is ever placed in the tree.
emacs/lisp/local.el
